{
	"compilerOptions": {
		"module": "nodenext",
		"target": "esnext",
		"outDir": "dist",
		"rootDir": "src",
		"types": [],
		"lib": ["esnext"],
		"declaration": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"include": ["src"]
}
